FROM node:22.22-alpine AS development

WORKDIR /usr/src/app

EXPOSE ${PORT}

# Defina a variável de ambiente NODE_ENV para "development"
ENV NODE_ENV=development

# pnpm via corepack (versão fixada no campo packageManager do package.json)
RUN corepack enable && corepack prepare pnpm@10.34.1 --activate

# Copie os arquivos do projeto
COPY package.json pnpm-lock.yaml ./

# Instale todas as dependências
RUN pnpm install --frozen-lockfile

# Copie o resto dos arquivos
COPY . .

# Comando de inicialização para desenvolvimento
CMD ["pnpm", "start:dev"]
